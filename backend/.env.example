# =============================================================================
# Mboa Drive Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# =============================================================================

# ─── Server Configuration ──────────────────────────────────────────────────
PORT=5000

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get from: https://app.supabase.com → Settings → Database → Connection String
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── JWT Security ────────────────────────────────────────────────────────────
# Generate a strong key (run: openssl rand -base64 32)
JWT_SECRET="your_ultra_secure_secret_key_here"
JWT_EXPIRES_IN="7d"

# ─── Google OAuth Configuration ──────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project named "Mboa Drive"
# 3. Enable Google Drive API
# 4. Create OAuth2 credentials (Web Application)
# 5. Add redirect URIs: http://localhost:5000/api/auth/google/callback
# 6. Use ONLY these scopes (configured in Google Cloud Console):
#    - .../auth/drive.file (create/manage own files)
#    - .../auth/drive.appdata (app configuration data)
#    - .../auth/drive.install (connect to Drive)
#    - .../auth/userinfo.email (user email)
#    - .../auth/userinfo.profile (user profile)
#    - openid (authentication)
# 
# NOTE: Gmail, Sheets, Docs scopes are NOT used to avoid Google verification warning

GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"
GOOGLE_REFRESH_TOKEN=""

# ─── Supabase Configuration (Standard Vercel Names) ──────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Service Role Key (for admin operations - keep secret!)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Frontend URL ────────────────────────────────────────────────────────────
# Used for redirect after Google OAuth callback
# Production: https://arlong-gamma.vercel.app
# Development: http://localhost:5173
FRONTEND_URL="https://arlong-gamma.vercel.app"

# ─── Firebase Storage (Optional) ───────────────────────────────────────────
# Only needed if using Firebase as secondary storage
# Get from: https://console.firebase.google.com → Project Settings → Service Accounts
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'  # JSON string
# FIREBASE_BUCKET="your-project.appspot.com"

# ─── Google AI / Gemini (Optional) ─────────────────────────────────────────
# Only needed for AI features (chat assistant, image analysis)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ─── Admin Configuration ──────────────────────────────────────────────────────
# Les comptes administrateur ne sont pas definis dans le code.
# Ils doivent exister dans la table "User" avec is_admin = true.

# ─── Optional: Update Server Configuration ───────────────────────────────────
# For electron-updater (desktop auto-update)
# UPDATE_SERVER_URL="https://arlong-gamma.vercel.app/api/versions"
GITHUB_TOKEN="your_github_token_here"