{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/web/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/web/index.html"
    }
  ]
}
