# =============================================================================
# Mboa Drive Desktop - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# =============================================================================

# ─── API Configuration ─────────────────────────────────────────────────────
# URL of the backend API (required)
VITE_API_URL=https://arlong-gamma.vercel.app/api

# ─── Supabase Configuration (for supabase.sh script) ───────────────────────
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase service role key (KEEP SECRET!)
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Auto-Updater Configuration ────────────────────────────────────────────
# URL for update server (optional, defaults to API)
# UPDATE_SERVER_URL=https://arlong-gamma.vercel.app/api/versions

# ─── Google OAuth Configuration ──────────────────────────────────────────────
# These are handled by the backend, no need to set them here
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Development Settings ──────────────────────────────────────────────────
# Set to 'true' to enable development mode features
# DEV_MODE=false
