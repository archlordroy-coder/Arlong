{
  "name": "desktop",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "author": "Mboa Drive Team <support@mboadrive.app>",
  "homepage": "https://arlong-gamma.vercel.app",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:exe": "electron-builder build --linux --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mboadrive.app",
    "productName": "Mboa Drive",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "public/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "firebase-admin": "^13.8.0",
    "googleapis": "^171.4.0",
    "jspdf": "^4.2.1",
    "localforage": "^1.10.0",
    "lucide-react": "^1.7.0",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "puppeteer-core": "^24.40.0",
    "puppeteer-in-electron": "^3.0.5",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "wwebjs-electron": "^1.34.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
